<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Galactic Mission Control</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header class="site-header">
        <div class="container nav-wrap">
            <a class="brand" asp-controller="Home" asp-action="Index">Galactic Mission Control</a>
            <nav>
                <ul class="nav-list">
                    <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a asp-controller="Mission" asp-action="Index">Missions</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <main class="container main-content" role="main">
        @RenderBody()
    </main>
</body>
</html>
